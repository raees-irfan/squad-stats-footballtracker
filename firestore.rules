rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && myDoc().role == 'admin';
    }

    // Approval is a separate flag from role: anyone can create a Firebase
    // Auth account (that endpoint is public - a hidden/removed "Sign up"
    // button in the app UI does NOT stop someone from calling it directly
    // with the same, non-secret, web config). This flag is what actually
    // gates read access to real data, regardless of how the account was
    // created. New accounts default to approved == false and get nothing
    // until an admin flips it - enforced here, not by the app UI.
    function isApproved() {
      return isSignedIn() && myDoc().approved == true;
    }

    match /users/{userId} {
      // Each user reads their own doc; admins can read the full roster
      // (needed for the approve/promote list). Not "any signed-in user
      // reads everyone's doc" - that would leak every user's email to
      // every other signed-in user for no functional benefit.
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // Self-signup: can only create your OWN doc, role must be "user",
      // and approved must be false - you cannot self-approve on creation.
      allow create: if isSignedIn()
                    && request.auth.uid == userId
                    && request.resource.data.role == 'user'
                    && request.resource.data.approved == false;

      // Self-edit (e.g. displayName): role AND approved must stay
      // unchanged. Admin-edit: can change anything, including someone
      // else's role/approved status.
      allow update: if isAdmin()
                    || (request.auth.uid == userId
                        && request.resource.data.role == resource.data.role
                        && request.resource.data.approved == resource.data.approved);

      allow delete: if isAdmin();
    }

    match /players/{playerId} {
      allow read: if isApproved() || isAdmin();
      // Admins can create/edit any player. A signed-in, approved user can
      // additionally create/edit a player doc if EITHER:
      //  - its ID equals their own auth uid (self-service creation - the
      //    ID *is* the uid, so "one profile per user" is structural), OR
      //  - its ownerUid field equals their uid (an admin manually linked
      //    an existing, admin-created player record to their account).
      // Both cases mean "this is genuinely their own profile" - the second
      // just covers players that existed before self-service did.
      allow create: if isAdmin() || (isApproved() && request.auth.uid == playerId);
      allow update: if isAdmin() || (
        isApproved() &&
        (request.auth.uid == playerId || ('ownerUid' in resource.data && resource.data.ownerUid == request.auth.uid))
      );
      allow delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if isApproved() || isAdmin();
      allow create, delete: if isAdmin();

      // Admins can edit anything (teams, score, events, votes, all of it).
      // A non-admin, approved user may ONLY do one narrow thing: touch the
      // `votes` map, and only their own key in it (request.auth.uid) - they
      // can't rewrite anyone else's vote or touch score/teams/events at all.
      // They're also allowed to flip pollClosed -> true / set mvpPlayerId,
      // but only once the vote count has actually reached 10 - that's what
      // lets the *voter whose vote hits #10* close the poll and record the
      // winner in the same write, without a backend function.
      // The `!('votes' in resource.data) ? ... : ...` branch exists because
      // matches logged BEFORE the MVP feature existed have no `votes` field
      // at all - calling .diff() against a genuinely missing field errors
      // out the whole rule (fails closed), which is exactly the "missing
      // or insufficient permissions" bug this fixes. When votes doesn't
      // exist yet, this is necessarily someone's very first vote on this
      // match, so it only needs to check the new map contains nothing but
      // their own key.
      // NOTE: this does not verify the mvpPlayerId is the *correct* winner
      // by tiebreak rules - that logic lives client-side only. For a small
      // trusted-friends app that's an acceptable trade-off; true tamper-proof
      // scoring would need a Cloud Function.
      allow update: if isAdmin() || (
        isApproved() &&
        resource.data.pollClosed != true &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes', 'pollClosed', 'mvpPlayerId']) &&
        (
          !('votes' in resource.data)
            ? request.resource.data.votes.keys().hasOnly([request.auth.uid])
            : request.resource.data.votes.diff(resource.data.votes).affectedKeys().hasOnly([request.auth.uid])
        ) &&
        (request.resource.data.pollClosed != true || request.resource.data.votes.size() >= 10)
      );
    }

    // Feedback creation isn't approval-gated - it's harmless (no data
    // exposure) and doubles as the channel a pending user can use to ask
    // an admin to approve them.
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
